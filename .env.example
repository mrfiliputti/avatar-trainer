# --- Azure Speech – Endpoint do recurso ---
# Use o domínio customizado para autenticação passwordless:
#   https://<custom-domain>.cognitiveservices.azure.com
# Ou o endpoint regional (apenas com chave):
#   https://<region>.api.cognitive.microsoft.com
SPEECH_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# --- Autenticação ---
# true  = usa DefaultAzureCredential (Azure CLI / Managed Identity / etc.)
#         A identidade precisa do papel "Cognitive Services User" ou
#         "Cognitive Services Speech User" no recurso de Speech.
# false = usa SPEECH_KEY abaixo
PASSWORDLESS=true
SPEECH_KEY=

# Tenant ID do diretório onde o recurso Speech vive (recomendado).
# Resolve o erro "Tenant provided in token does not match resource tenant"
# quando você está logado em múltiplos tenants no Azure CLI.
# Obtenha com:  az account show --query tenantId -o tsv
AZURE_TENANT_ID=

# --- Voz e Avatar ---
AZURE_TTS_VOICE=en-US-Ava:DragonHDLatestNeural
AZURE_AVATAR_CHARACTER=Lisa
AZURE_AVATAR_STYLE=casual-sitting

# Cor RGBA hex (ex.: #FFFFFFFF) ou 'transparent'
AZURE_AVATAR_BACKGROUND=#FFFFFFFF
# Opcional – URL https de imagem de fundo (substitui a cor)
# AZURE_AVATAR_BACKGROUND_IMAGE=

# mp4 | webm   (webm é necessário para fundo transparente)
AZURE_AVATAR_VIDEO_FORMAT=mp4
# h264 | hevc | vp9   (vp9 é necessário para fundo transparente)
AZURE_AVATAR_VIDEO_CODEC=h264

# Avatar customizado (true/false)
AZURE_AVATAR_CUSTOMIZED=false
AZURE_AVATAR_USE_BUILT_IN_VOICE=false
